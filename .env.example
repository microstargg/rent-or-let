# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/neondb?sslmode=require

# Neon Auth — enable in Neon Console → Auth, then copy Auth URL
NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.eu-west-2.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=replace-with-32-char-random-secret-from-openssl-rand-base64-32

# Public site
NEXT_PUBLIC_SITE_URL=https://www.rent-or-let.co.uk

# Vercel Blob (property images in production)
BLOB_READ_WRITE_TOKEN=

# Cron
CRON_SECRET=generate-a-random-secret

# Email (Resend)
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# Rightmove RTDF
# Base64-encode your .pem keystore: certutil -encode file.pem tmp.b64 && type tmp.b64 (Windows)
# or: base64 -i file.pem | tr -d '\n' (macOS/Linux)
RIGHTMOVE_NETWORK_ID=
RIGHTMOVE_BRANCH_ID=
RIGHTMOVE_CERT_PEM=
RIGHTMOVE_CERT_PASSWORD=
# Sandbox (during beta testing): https://adfapi.adftest.rightmove.com/v1/property/
# Production (default if unset): https://adfapi.rightmove.co.uk/v1/property/
RIGHTMOVE_RTDF_URL=

# OnTheMarket RTDF
OTM_NETWORK_ID=
OTM_BRANCH_ID=
OTM_CERT_PEM=
OTM_CERT_PASSWORD=
